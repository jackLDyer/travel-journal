---
import { getImage } from "astro:assets";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getTrips } from "@/lib/trips";
import { withBase } from "@/lib/routes";

const trips = getTrips();
const tripsWithCovers = await Promise.all(
  trips.map(async (trip) => {
    if (!trip.cover) {
      return { ...trip, coverImage: null };
    }

    const coverWidths = [360, 540, 720, 960].filter((width) => width <= trip.cover!.src.width);
    const coverImages = await Promise.all(
      coverWidths.map((width) =>
        getImage({
          src: trip.cover!.src,
          width,
          format: "webp",
          quality: 76,
        }),
      ),
    );
    const fallback = await getImage({
      src: trip.cover.src,
      width: Math.min(360, trip.cover.src.width),
      format: "webp",
      quality: 76,
    });

    return {
      ...trip,
      coverImage: {
        src: fallback.src,
        srcset: coverImages.map((image) => `${image.src} ${image.options.width}w`).join(", "),
      },
    };
  }),
);
---

<BaseLayout title="Travel Journal">
  <section class="hero">
    <p class="eyebrow">Personal atlas</p>
    <h1>Trips, days, stories and photographs.</h1>
    <p class="lede">
      A quiet static archive for travel journals.
    </p>
  </section>

  <section class="section trips-section" aria-labelledby="trips-heading">
    <h2 id="trips-heading">Trips</h2>
    {trips.length === 0 ? (
      <div class="empty-state">
        <h3>No trips yet</h3>
        <p>
          Create <code>src/content/trips/my-trip/days/2026-05-14/summary.md</code>
          and add photos under the matching <code>photos/</code> folder.
        </p>
      </div>
    ) : (
      <div class="grid">
        {tripsWithCovers.map((trip) => (
          <a class="card" href={withBase(`/trips/${trip.slug}/`)}>
            <div class="card-media">
              {trip.cover && trip.coverImage && (
                <img
                  src={trip.coverImage.src}
                  srcset={trip.coverImage.srcset}
                  alt={trip.cover.alt}
                  sizes="(max-width: 740px) calc(100vw - 32px), 360px"
                  loading="lazy"
                  decoding="async"
                  width={trip.cover.src.width}
                  height={trip.cover.src.height}
                />
              )}
            </div>
            <div class="card-body">
              <p class="eyebrow">{trip.days.length} day{trip.days.length === 1 ? "" : "s"}</p>
              <h3>{trip.title}</h3>
              {trip.description && <p class="meta">{trip.description}</p>}
            </div>
          </a>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
