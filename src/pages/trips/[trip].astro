---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { formatDisplayDate, getTrips } from "@/lib/trips";
import { withBase } from "@/lib/routes";

export function getStaticPaths() {
  return getTrips().map((trip) => ({
    params: { trip: trip.slug },
    props: { trip },
  }));
}

const { trip } = Astro.props;
const Intro = trip.intro?.Content;
const Summary = trip.summary?.Content;
---

<BaseLayout title={`${trip.title} | Travel Journal`} description={trip.description}>
  <section class="hero">
    <p class="eyebrow">Trip journal</p>
    <h1>{trip.title}</h1>
    {trip.description && <p class="lede">{trip.description}</p>}
  </section>

  {Intro && (
    <section class="section prose trip-intro">
      <Intro />
    </section>
  )}

  {Summary && (
    <section class="section prose trip-summary">
      <Summary />
    </section>
  )}

  <section class="section days-section" aria-labelledby="days-heading">
    <h2 id="days-heading">Days</h2>
    {trip.days.length === 0 ? (
      <div class="empty-state">
        <h3>No days yet</h3>
        <p>Add dated folders under <code>src/content/trips/{trip.slug}/days/</code>.</p>
      </div>
    ) : (
      <div class="timeline">
        {trip.days.map((day) => {
          const displayDate = formatDisplayDate(day.date);
          const locations = day.locations.length > 0 ? day.locations : day.location ? [day.location] : [];

          return (
            <a class="day-link" href={withBase(`/trips/${trip.slug}/${day.date}/`)}>
              <span class="date-pill">{day.ordinalLabel}</span>
              <span class="day-details">
                <strong>{day.title}</strong>
                {day.title !== displayDate && <span class="meta">{displayDate}</span>}
                {locations.length > 0 && (
                  <span class="meta">{locations.join(", ")}</span>
                )}
                {day.highlights.length > 0 && (
                  <span class="meta">Highlights: {day.highlights.join(", ")}</span>
                )}
              </span>
              <span class="meta photo-count">{day.photos.length} photo{day.photos.length === 1 ? "" : "s"}</span>
            </a>
          );
        })}
      </div>
    )}
  </section>
</BaseLayout>
